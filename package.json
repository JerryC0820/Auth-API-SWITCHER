{
  "name": "codex-workspace-switcher",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop app for switching between OpenAI Codex workspace auth profiles.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:host": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\restart-dev.ps1 -Mode DevHostStart",
    "dev:host:fresh": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron:host\"",
    "dev:host:reuse-renderer": "concurrently -k \"npm:dev:main\" \"npm:dev:electron:host\"",
    "dev:renderer": "vite",
    "dev:main": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --format=cjs --target=node20 --outdir=dist-electron --external:electron --entry-names=[name] --sourcemap --watch",
    "dev:electron": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\restart-dev.ps1 -Mode DevElectronLoop",
    "dev:electron:host": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\restart-dev.ps1 -Mode DevElectronLoop -ElectronArgs 'license-host-mode'",
    "cf:auth:dev": "npx wrangler dev --config workers/auth-api/wrangler.jsonc --local",
    "cf:auth:deploy": "npx wrangler deploy --config workers/auth-api/wrangler.jsonc",
    "cf:auth:whoami": "npx wrangler whoami",
    "cf:auth:d1:create": "npx wrangler d1 create auth-api-switcher-db",
    "cf:auth:d1:migrate:local": "npx wrangler d1 migrations apply auth-api-switcher-db --local --config workers/auth-api/wrangler.jsonc",
    "cf:auth:d1:migrate:remote": "npx wrangler d1 migrations apply auth-api-switcher-db --remote --config workers/auth-api/wrangler.jsonc",
    "build:resources": "node .\\scripts\\prepare-build-assets.mjs",
    "typecheck": "tsc --noEmit",
    "build:renderer": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\build-renderer.ps1",
    "build:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --format=cjs --target=node20 --outdir=dist-electron --external:electron --entry-names=[name]",
    "build": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build.ps1",
    "dist": "powershell -ExecutionPolicy Bypass -File .\\scripts\\dist.ps1 -Target win",
    "dist:win": "powershell -ExecutionPolicy Bypass -File .\\scripts\\dist.ps1 -Target win",
    "dist:mac": "powershell -ExecutionPolicy Bypass -File .\\scripts\\dist.ps1 -Target mac",
    "dist:dir": "powershell -ExecutionPolicy Bypass -File .\\scripts\\dist.ps1 -Target dir",
    "release:manifest": "node .\\scripts\\release-manifest.mjs --channel stable"
  },
  "dependencies": {
    "@fontsource/space-grotesk": "^5.2.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "clsx": "^2.1.1",
    "fs-extra": "^11.3.4",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4",
    "wrangler": "^4.75.0"
  },
  "build": {
    "appId": "com.jerryc0820.auth-api-switcher",
    "productName": "Auth API Switcher",
    "afterPack": "./scripts/electron-builder-after-pack.cjs",
    "directories": {
      "output": "release-artifacts",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "artifactName": "${productName}-${version}-win-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "category": "public.app-category.developer-tools"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/installerIcon.ico",
      "uninstallerIcon": "build/uninstallerIcon.ico",
      "installerHeaderIcon": "build/installerHeaderIcon.ico",
      "license": "build/license.txt"
    },
    "dmg": {
      "sign": false,
      "contents": [
        {
          "x": 180,
          "y": 220
        },
        {
          "x": 460,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
